# Netlify / Cloudflare Pages header config.
# sqlite-wasm's OPFS VFS needs SharedArrayBuffer + cross-origin isolation
# to mount cleanly. Without these two headers, Chrome falls through to
# the slower SAH Pool VFS and logs a loud warning at boot; Safari refuses
# SharedArrayBuffer entirely. The CORS/CORP settings on our Google Fonts
# links are already cross-origin-compatible, so no other CDN breakage.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

# Static assets: a year of immutable caching is safe because every file
# is content-hashed by Vite (e.g. index-B7Ykm1xv.css).
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker must NOT be cached long — browsers re-fetch it to check
# for updates; a stale SW would pin users to an older app version.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
